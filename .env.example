# ── VetBuddy Open API (Read) ──────────────────
VETBUDDY_APP_URL=http://your-instance.thevetbuddy.com/vetbuddy
VETBUDDY_UID=your_api_uid
VETBUDDY_PASSWD=your_api_password

# ── VetBuddy Push API (Write) ─────────────────
VETBUDDY_PUSH_URL=http://your-instance.thevetbuddy.com
VETBUDDY_INSTANCE=your_instance_id
VETBUDDY_PUSH_KEY=your_push_api_key

# ── RDS MySQL Database ────────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# ── Server ────────────────────────────────────
PORT=3000
